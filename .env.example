# LMCS LLM IA - Variáveis de Ambiente
# Copie este arquivo para .env e ajuste conforme necessário
# Uso: source .env

# ============================================
# AMBIENTE
# ============================================
# development, staging, production, test
LMCS_ENV=development

# ============================================
# TREINAMENTO
# ============================================
# Número de épocas de treinamento
LMCS_EPOCHS=300

# Taxa de aprendizado (0.001 recomendado)
LMCS_LEARNING_RATE=0.001

# Tamanho do batch (16-64 típico)
LMCS_BATCH_SIZE=16

# Temperatura para geração (0.6-0.8 ideal para conversas)
LMCS_TEMPERATURE=0.7

# Top-K sampling (30-40 recomendado)
LMCS_TOP_K=30

# ============================================
# ARQUITETURA TRANSFORMER
# ============================================
# Dimensão do modelo (deve ser múltiplo de 64)
# Valores comuns: 128, 256, 512, 768, 1024
LMCS_D_MODEL=512

# Número de attention heads (deve dividir d_model)
# Valores comuns: 4, 8, 12, 16
LMCS_N_HEADS=8

# Número de camadas Transformer
# Valores comuns: 2-12
LMCS_NUM_LAYERS=6

# Tamanho máximo da sequência (deve ser múltiplo de 32)
LMCS_MAX_SEQ_LEN=256

# Hidden size do feed-forward (deve ser >= d_model)
LMCS_FF_HIDDEN=1024

# Tamanho máximo do vocabulário
LMCS_MAX_VOCAB=5000

# ============================================
# REGULARIZAÇÃO
# ============================================
# Taxa de dropout (0.0-0.5)
LMCS_DROPOUT_RATE=0.1

# Weight decay / L2 regularization (0.0-0.5)
LMCS_WEIGHT_DECAY=0.01

# ============================================
# SERVIDOR HTTP
# ============================================
# Porta do servidor (deve começar com :)
LMCS_PORT=:8080

# Host do servidor
LMCS_HOST=localhost

# ============================================
# PATHS
# ============================================
# Caminho do modelo salvo
LMCS_MODEL_PATH=lmcs-model.bin

# Arquivo de dataset de treinamento
LMCS_INPUT_FILE=dataset/data/train_enriched.txt
